@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" title="Manage">
                👤 @User.Identity?.Name
            </a>
        </li>
        @if (UserManager.GetUserId(User) != null && User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link" asp-controller="GameDevRoleRequests" asp-action="Manage" title="Game Dev Requests">
                    🛡️
                </a>
            </li>
        }
        @if (!User.IsInRole("Admin") && !User.IsInRole("GameDev"))
        {
            <li class="nav-item">
                <a class="nav-link" asp-controller="GameDevRoleRequests" asp-action="MyRequest">🎮 Game Dev</a>
            </li>
        }
        @if (User.IsInRole("GameDev"))
        {
            <li class="nav-item">
                <a class="nav-link" asp-controller="AddGameRequests" asp-action="AddGame" title="Submit Game">
                    🕹️
                </a>
            </li>
        }
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link" asp-controller="AddGameRequests" asp-action="Manage" title="Game Add Requests">
                    🎮
                </a>
            </li>
        }
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" ...>
                <button type="submit" class="nav-link">🚪 Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">📝 Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">🔐 Login</a>
        </li>
    }
</ul>