<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Game Reviews</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Game_reviews.styles.css" asp-append-version="true" />
    <style>
        /* Custom success alert – dark theme, gold accents */
        .success-alert {
            background: linear-gradient(135deg, #0a192f 0%, #0c1f38 100%);
            border-left: 6px solid #d4af37;
            border-radius: 12px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(212, 175, 55, 0.2);
            backdrop-filter: blur(4px);
            min-width: 320px;
            max-width: 450px;
            transition: opacity 0.3s ease, transform 0.2s ease;
            animation: slideInRight 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }

        .alert-content {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.2rem;
        }

        .alert-icon {
            font-size: 2rem;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
        }

        .alert-message {
            flex: 1;
            color: #e0e0e0;
            font-size: 0.95rem;
            font-weight: 400;
            line-height: 1.4;
        }

        .alert-close {
            background: none;
            border: none;
            color: #d4af37;
            font-size: 1.3rem;
            cursor: pointer;
            padding: 0 0.2rem;
            transition: color 0.2s;
            opacity: 0.7;
        }

            .alert-close:hover {
                opacity: 1;
                color: #f5c542;
            }

        /* Special library button inside alert */
        .btn-library {
            background-color: #d4af37;
            border: none;
            color: #0a192f !important;
            font-weight: 600;
            padding: 0.3rem 0.9rem;
            border-radius: 20px;
            font-size: 0.8rem;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-library:hover {
                background-color: #e6c352;
                transform: translateY(-1px);
                box-shadow: 0 2px 8px rgba(212, 175, 55, 0.3);
                color: #051020;
            }

        /* Global dark navy theme */
        body {
            background-color: #0a192f;
            color: #e0e0e0;
        }

        /* Navbar – deep navy with gold accents */
        .navbar {
            background-color: #051020 !important;
            border-bottom: 1px solid #d4af37 !important;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
        }

        .navbar-brand {
            color: #d4af37 !important;
            font-weight: 300;
            letter-spacing: 0.5px;
        }

            .navbar-brand:hover {
                color: #b49450 !important;
            }

        .navbar-nav .nav-link {
            color: #e0e0e0 !important;
            transition: color 0.2s;
        }

            .navbar-nav .nav-link:hover {
                color: #d4af37 !important;
            }

        .navbar-toggler {
            border-color: #d4af37 !important;
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='%23d4af37' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
        }

        .navbar-nav .nav-item .nav-link,
        .navbar-nav .nav-item form button {
            color: #e0e0e0 !important;
            background: transparent;
            border: none;
            padding: 0.5rem 1rem;
            transition: color 0.2s;
        }

            .navbar-nav .nav-item .nav-link:hover,
            .navbar-nav .nav-item form button:hover {
                color: #d4af37 !important;
                text-decoration: none;
            }

        a:focus-visible,
        button:focus-visible,
        .navbar-toggler:focus-visible,
        .nav-link:focus-visible {
            outline: 2px solid #d4af37 !important;
            outline-offset: 2px;
        }

        .container {
            background-color: transparent;
        }

        main {
            min-height: calc(100vh - 120px);
        }

        .btn-outline-gold {
            background-color: transparent;
            border: 1px solid #d4af37;
            color: #e0e0e0;
        }

            .btn-outline-gold:hover {
                background-color: rgba(212, 175, 55, 0.2);
                border-color: #d4af37;
                color: #d4af37;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Games" asp-action="Index">🎮 Game Reviews</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Games" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Games" asp-action="Library">My Library</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
            <div id="successAlert" class="success-alert" role="alert">
                <div class="alert-content">
                    <div class="alert-icon">✅</div>
                    <div class="alert-message">
                        @TempData["SuccessMessage"]
                        <div class="mt-2">
                            <a asp-controller="Games" asp-action="Library" class="btn btn-library">
                                📚 View Library
                            </a>
                        </div>
                    </div>
                    <button type="button" class="alert-close" data-dismiss="alert" aria-label="Close">✕</button>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var alertEl = document.getElementById('successAlert');
                if (alertEl) {
                    // Auto-hide after 5 seconds
                    setTimeout(function () {
                        alertEl.style.opacity = '0';
                        setTimeout(function () {
                            alertEl.remove();
                        }, 300);
                    }, 5000);

                    // Close button functionality
                    var closeBtn = alertEl.querySelector('.alert-close');
                    if (closeBtn) {
                        closeBtn.addEventListener('click', function () {
                            alertEl.style.opacity = '0';
                            setTimeout(function () { alertEl.remove(); }, 300);
                        });
                    }
                }
            });
        </script>
    }
</body>
</html>