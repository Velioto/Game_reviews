@model Game_reviews.Models.GameDevRoleRequest?

@{
    ViewData["Title"] = "My Game Dev Request";
}

<style>
    .status-card {
        background-color: rgba(255,255,255,0.04);
        border: 1px solid rgba(212,175,55,0.25);
        border-radius: 0.75rem;
        padding: 2rem;
        max-width: 620px;
        margin: 2rem auto;
    }

    .status-card h2 { color: #d4af37; font-weight: 300; margin-bottom: 1.5rem; }

    .status-badge {
        display: inline-block;
        padding: 0.3rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .status-Pending  { background: rgba(212,175,55,0.15); color: #d4af37; border: 1px solid rgba(212,175,55,0.4); }
    .status-Approved { background: rgba(60,180,100,0.15); color: #5eca80; border: 1px solid rgba(60,180,100,0.4); }
    .status-Denied   { background: rgba(220,60,60,0.15);  color: #e87070; border: 1px solid rgba(220,60,60,0.4); }

    .request-message {
        font-size: 0.9rem;
        color: #c0cdd8;
        border-left: 3px solid rgba(212,175,55,0.3);
        padding-left: 0.8rem;
        margin: 1rem 0;
    }

    .meta { font-size: 0.82rem; color: #7a8fa0; margin-bottom: 1rem; }

    .admin-note { font-size: 0.85rem; color: #e87070; margin-top: 0.8rem; }

    .btn-submit-new {
        background-color: #b49450;
        color: #0a192f;
        border: none;
        padding: 0.6rem 2rem;
        font-weight: 600;
        border-radius: 0.375rem;
        text-decoration: none;
        display: inline-block;
        margin-top: 1rem;
        transition: background-color 0.2s;
    }

    .btn-submit-new:hover { background-color: #d4af37; color: #051020; }

    .empty-state { text-align: center; color: #a0b0c0; }
    .empty-state p { margin-bottom: 1.5rem; }
</style>

<div class="status-card">
    <h2>🎮 My Game Dev Request</h2>

    @if (Model == null)
    {
        <div class="empty-state">
            <p>You haven't submitted a request yet.</p>
            <a asp-action="Submit" class="btn-submit-new">Send a Request</a>
        </div>
    }
    else
    {
        <span class="status-badge status-@Model.Status.ToString()">@Model.Status</span>

        <div class="meta">Submitted: @Model.SubmittedAt.ToString("MMM d, yyyy 'at' HH:mm")</div>

        <div class="request-message"><em>"@Model.Message"</em></div>

        @if (Model.Status == Game_reviews.Models.GameDevRoleRequestStatus.Denied)
        {
            @if (!string.IsNullOrEmpty(Model.AdminNote))
            {
                <div class="admin-note">❌ Admin note: @Model.AdminNote</div>
            }
            <a asp-action="Submit" class="btn-submit-new">Try Again</a>
        }

        @if (Model.Status == Game_reviews.Models.GameDevRoleRequestStatus.Approved)
        {
            <div style="color:#5eca80; margin-top:0.8rem;">
                ✅ You now have the Game Dev role!
            </div>
        }
    }
</div>