@{
    ViewData["Title"] = "Request Game Dev Role";
}

<style>
    .form-card {
        background-color: rgba(255,255,255,0.04);
        border: 1px solid rgba(212,175,55,0.25);
        border-radius: 0.75rem;
        padding: 2rem;
        max-width: 620px;
        margin: 2rem auto;
    }

        .form-card h2 {
            color: #d4af37;
            font-weight: 300;
            margin-bottom: 0.4rem;
        }

        .form-card .subtitle {
            color: #a0b0c0;
            font-size: 0.9rem;
            margin-bottom: 1.8rem;
        }

    .form-label {
        color: #d4af37;
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.5px;
        margin-bottom: 0.3rem;
    }

    .form-control, .form-control:focus {
        background-color: #1e2a3a;
        color: #e0e0e0;
        border: 1px solid rgba(212,175,55,0.4);
        border-radius: 0.375rem;
    }

        .form-control:focus {
            border-color: #d4af37;
            box-shadow: 0 0 0 0.2rem rgba(212,175,55,0.15);
        }

    .btn-submit {
        background-color: #b49450;
        color: #0a192f;
        border: none;
        padding: 0.6rem 2rem;
        font-weight: 600;
        border-radius: 0.375rem;
        transition: background-color 0.2s;
    }

        .btn-submit:hover {
            background-color: #d4af37;
            color: #051020;
        }
</style>

<div class="form-card">
    <h2>🎮 Request Game Dev Role</h2>
    <p class="subtitle">Tell us why you'd like to become a Game Dev. An admin will review your request.</p>

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="color:#e87070; margin-bottom:1rem;">⚠️ @TempData["ErrorMessage"]</div>
    }

    <form asp-action="Submit" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-4">
            <label class="form-label">Your Message</label>
            <textarea name="message" class="form-control" rows="5"
                      placeholder="Explain why you want to be a Game Dev..." required></textarea>
        </div>
        <button type="submit" class="btn-submit">Send Request</button>
    </form>
</div>