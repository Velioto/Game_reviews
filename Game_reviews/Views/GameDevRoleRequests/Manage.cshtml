@model List<Game_reviews.Models.GameDevRoleRequest>
@{
    ViewData["Title"] = "Game Dev Role Requests";
}

<style>
    .page-header h2 {
        color: #d4af37;
        font-weight: 300;
        margin-bottom: 1.8rem;
    }

    .tabs {
        display: flex;
        gap: .5rem;
        margin-bottom: 1.8rem;
        border-bottom: 1px solid rgba(212,175,55,.2);
    }

    .tab-btn {
        background: none;
        border: none;
        color: #a0b0c0;
        font-size: .9rem;
        padding: .5rem 1.2rem .6rem;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        transition: all .2s;
    }

        .tab-btn.active, .tab-btn:hover {
            color: #d4af37;
            border-bottom-color: #d4af37;
        }

    .request-card {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(212,175,55,.2);
        border-radius: .75rem;
        padding: 1.4rem 1.6rem;
        margin-bottom: 1.2rem;
    }

        .request-card.pending {
            border-left: 4px solid #d4af37;
        }

        .request-card.approved {
            border-left: 4px solid #5eca80;
        }

        .request-card.denied {
            border-left: 4px solid #e87070;
        }

    .request-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #e0e0e0;
    }

    .request-meta {
        font-size: .82rem;
        color: #7a8fa0;
        margin: .3rem 0 .7rem;
    }

    .request-message {
        font-size: .9rem;
        color: #c0cdd8;
        border-left: 3px solid rgba(212,175,55,.3);
        padding-left: .8rem;
        margin-bottom: .8rem;
    }

    .action-row {
        display: flex;
        gap: .75rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-approve {
        background: rgba(60,180,100,.2);
        color: #5eca80;
        border: 1px solid rgba(60,180,100,.5);
        padding: .4rem 1.2rem;
        border-radius: .375rem;
        font-size: .88rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
    }

        .btn-approve:hover {
            background: rgba(60,180,100,.35);
        }

    .deny-section {
        display: flex;
        gap: .5rem;
        align-items: center;
        flex: 1;
        min-width: 240px;
    }

    .deny-note-input {
        background: #1e2a3a;
        color: #e0e0e0;
        border: 1px solid rgba(220,60,60,.4);
        border-radius: .375rem;
        padding: .4rem .7rem;
        font-size: .85rem;
        flex: 1;
    }

        .deny-note-input:focus {
            outline: none;
            border-color: #e87070;
        }

    .btn-deny {
        background: rgba(220,60,60,.2);
        color: #e87070;
        border: 1px solid rgba(220,60,60,.5);
        padding: .4rem 1rem;
        border-radius: .375rem;
        font-size: .88rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
    }

        .btn-deny:hover {
            background: rgba(220,60,60,.35);
        }

    .status-badge {
        display: inline-block;
        padding: .2rem .7rem;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 600;
    }

    .status-Pending {
        background: rgba(212,175,55,.15);
        color: #d4af37;
    }

    .status-Approved {
        background: rgba(60,180,100,.15);
        color: #5eca80;
    }

    .status-Denied {
        background: rgba(220,60,60,.15);
        color: #e87070;
    }

    .admin-note-display {
        font-size: .83rem;
        color: #e87070;
        margin-top: .4rem;
    }

    .empty-state {
        text-align: center;
        padding: 2.5rem;
        color: #7a8fa0;
        border: 1px dashed rgba(212,175,55,.2);
        border-radius: .75rem;
    }

    .tab-content {
        display: none;
    }

        .tab-content.active {
            display: block;
        }
</style>

<div class="container mt-4" style="max-width:820px;">
    <div class="page-header"><h2>🛡️ Game Dev Role Requests</h2></div>

    @{
        var pending = Model.Where(r => r.Status == Game_reviews.Models.GameDevRoleRequestStatus.Pending).ToList();
        var approved = Model.Where(r => r.Status == Game_reviews.Models.GameDevRoleRequestStatus.Approved).ToList();
        var denied = Model.Where(r => r.Status == Game_reviews.Models.GameDevRoleRequestStatus.Denied).ToList();
    }

    <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('pending',this)">
            Pending <span style="color:#d4af37">(@pending.Count)</span>
        </button>
        <button class="tab-btn" onclick="switchTab('approved',this)">
            Approved <span style="color:#5eca80">(@approved.Count)</span>
        </button>
        <button class="tab-btn" onclick="switchTab('denied',this)">
            Denied <span style="color:#e87070">(@denied.Count)</span>
        </button>
    </div>

    <!-- PENDING -->
    <div id="tab-pending" class="tab-content active">
        @if (!pending.Any())
        {
            <div class="empty-state">No pending requests 🎉</div>
        }
        @foreach (var req in pending)
        {
            <div class="request-card pending">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="request-title">👤 @(req.User?.Email ?? req.UserId)</div>
                    <span class="status-badge status-Pending">Pending</span>
                </div>
                <div class="request-meta">
                    Submitted: @req.SubmittedAt.ToString("MMM d, yyyy 'at' HH:mm")
                </div>
                <div class="request-message">
                    <em>"@req.Message"</em>
                </div>
                <div class="action-row">
                    <form asp-action="Approve" asp-route-id="@req.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-approve">✅ Approve</button>
                    </form>
                    <form asp-action="Deny" asp-route-id="@req.Id" method="post" class="deny-section">
                        @Html.AntiForgeryToken()
                        <input type="text" name="adminNote" class="deny-note-input" placeholder="Reason (optional)..." />
                        <button type="submit" class="btn-deny">❌ Deny</button>
                    </form>
                </div>
            </div>
        }
    </div>

    <!-- APPROVED -->
    <div id="tab-approved" class="tab-content">
        @if (!approved.Any())
        {
            <div class="empty-state">No approved requests yet.</div>
        }
        @foreach (var req in approved)
        {
            <div class="request-card approved">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="request-title">👤 @(req.User?.Email ?? req.UserId)</div>
                    <span class="status-badge status-Approved">Approved</span>
                </div>
                <div class="request-meta">
                    Submitted: @req.SubmittedAt.ToString("MMM d, yyyy 'at' HH:mm")
                </div>
                <div class="request-message">
                    <em>"@req.Message"</em>
                </div>
            </div>
        }
    </div>

    <!-- DENIED -->
    <div id="tab-denied" class="tab-content">
        @if (!denied.Any())
        {
            <div class="empty-state">No denied requests.</div>
        }
        @foreach (var req in denied)
        {
            <div class="request-card denied">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="request-title">👤 @(req.User?.Email ?? req.UserId)</div>
                    <span class="status-badge status-Denied">Denied</span>
                </div>
                <div class="request-meta">
                    Submitted: @req.SubmittedAt.ToString("MMM d, yyyy 'at' HH:mm")
                </div>
                <div class="request-message">
                    <em>"@req.Message"</em>
                </div>
                @if (!string.IsNullOrEmpty(req.AdminNote))
                {
                    <div class="admin-note-display">❌ Reason: @req.AdminNote</div>
                }
            </div>
        }
    </div>
</div>

<script>
    function switchTab(name, btn) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + name).classList.add('active');
        btn.classList.add('active');
    }
</script>