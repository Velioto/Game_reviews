@model Game_reviews.Models.AddGameRequestViewModel

@{
    ViewData["Title"] = "Add Game Request";
}

<style>
    .form-card {
        background-color: rgba(255,255,255,0.04);
        border: 1px solid rgba(212,175,55,0.25);
        border-radius: 0.75rem;
        padding: 2rem;
        max-width: 720px;
        margin: 2rem auto;
    }

        .form-card h2 {
            color: #d4af37;
            font-weight: 300;
            margin-bottom: 0.4rem;
        }

        .form-card .subtitle {
            color: #a0b0c0;
            font-size: 0.9rem;
            margin-bottom: 1.8rem;
        }

    .form-label {
        color: #d4af37;
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.5px;
        margin-bottom: 0.3rem;
    }

    .form-control, .form-control:focus {
        background-color: #1e2a3a;
        color: #e0e0e0;
        border: 1px solid rgba(212,175,55,0.4);
        border-radius: 0.375rem;
    }

        .form-control:focus {
            border-color: #d4af37;
            box-shadow: 0 0 0 0.2rem rgba(212,175,55,0.15);
        }

    .genre-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 0.6rem;
        margin-top: 0.4rem;
    }

    .genre-check-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .genre-check-item input[type="checkbox"] {
            accent-color: #d4af37;
            width: 1rem;
            height: 1rem;
        }

        .genre-check-item label {
            color: #e0e0e0;
            font-size: 0.9rem;
            margin: 0;
            cursor: pointer;
        }

    .btn-submit {
        background-color: #b49450;
        color: #0a192f;
        border: none;
        padding: 0.6rem 2rem;
        font-weight: 600;
        border-radius: 0.375rem;
        transition: background-color 0.2s;
    }

        .btn-submit:hover {
            background-color: #d4af37;
            color: #051020;
        }

    .divider {
        border-color: rgba(212,175,55,0.2);
        margin: 1.5rem 0;
    }

    .text-danger {
        color: #e87070 !important;
    }
</style>

<div class="form-card">
    <h2>🎮 Submit a Game Request</h2>
    <p class="subtitle">Fill in the game details below. An admin will review and approve your submission.</p>

    <form asp-action="AddGame" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="GameTitle" class="form-label">Game Title</label>
            <input asp-for="GameTitle" class="form-control" placeholder="e.g. Dark Souls IV" />
            <span asp-validation-for="GameTitle" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="GameDescription" class="form-label">Description</label>
            <textarea asp-for="GameDescription" class="form-control" rows="4"
                      placeholder="A brief description of the game..."></textarea>
            <span asp-validation-for="GameDescription" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="BannerUrl" class="form-label">Banner Image URL <span style="color:#a0b0c0;font-weight:400;">(optional)</span></label>
            <input asp-for="BannerUrl" class="form-control" placeholder="https://..." />
        </div>

        <div class="mb-3">
            <label asp-for="ReleaseDate" class="form-label">Release Date</label>
            <input asp-for="ReleaseDate" class="form-control" type="date" />
            <span asp-validation-for="ReleaseDate" class="text-danger small"></span>
        </div>

        @if (Model.AllGenres.Any())
        {
            <div class="mb-3">
                <label class="form-label">Genres</label>
                <div class="genre-grid">
                    @foreach (var genre in Model.AllGenres)
                    {
                        <div class="genre-check-item">
                            <input type="checkbox"
                                   name="SelectedGenreIds"
                                   value="@genre.Id"
                                   id="genre_@genre.Id"
                                   @(Model.SelectedGenreIds.Contains(genre.Id) ? "checked" : "") />
                            <label for="genre_@genre.Id">@genre.Name</label>
                        </div>
                    }
                </div>
            </div>
        }

        <hr class="divider" />

        <div class="mb-4">
            <label asp-for="Message" class="form-label">Message to Admin</label>
            <textarea asp-for="Message" class="form-control" rows="3"
                      placeholder="Tell the admin why this game should be added..."></textarea>
            <span asp-validation-for="Message" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-3 align-items-center">
            <button type="submit" class="btn-submit">Submit Request</button>
            <a asp-action="MyRequests" style="color:#a0b0c0; font-size:0.9rem;">View My Requests</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}