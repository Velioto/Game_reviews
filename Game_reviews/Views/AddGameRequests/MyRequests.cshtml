@model List<Game_reviews.Models.AddGameRequest>

@{
    ViewData["Title"] = "My Game Requests";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

        .page-header h2 {
            color: #d4af37;
            font-weight: 300;
            margin: 0;
        }

    .btn-gold {
        background-color: #b49450;
        color: #0a192f;
        border: none;
        padding: 0.5rem 1.4rem;
        font-weight: 600;
        border-radius: 0.375rem;
        text-decoration: none;
        transition: background-color 0.2s;
    }

        .btn-gold:hover {
            background-color: #d4af37;
            color: #051020;
        }

    .request-card {
        background-color: rgba(255,255,255,0.04);
        border: 1px solid rgba(212,175,55,0.2);
        border-radius: 0.75rem;
        padding: 1.4rem 1.6rem;
        margin-bottom: 1.2rem;
    }

        .request-card.pending {
            border-left: 4px solid #d4af37;
        }

        .request-card.approved {
            border-left: 4px solid #5eca80;
        }

        .request-card.denied {
            border-left: 4px solid #e87070;
        }

    .request-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #e0e0e0;
        margin-bottom: 0.3rem;
    }

    .request-meta {
        font-size: 0.82rem;
        color: #7a8fa0;
        margin-bottom: 0.7rem;
    }

    .request-message {
        font-size: 0.9rem;
        color: #c0cdd8;
        border-left: 3px solid rgba(212,175,55,0.3);
        padding-left: 0.8rem;
        margin-bottom: 0.6rem;
    }

    .status-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .status-Pending {
        background: rgba(212,175,55,0.15);
        color: #d4af37;
        border: 1px solid rgba(212,175,55,0.4);
    }

    .status-Approved {
        background: rgba(60,180,100,0.15);
        color: #5eca80;
        border: 1px solid rgba(60,180,100,0.4);
    }

    .status-Denied {
        background: rgba(220,60,60,0.15);
        color: #e87070;
        border: 1px solid rgba(220,60,60,0.4);
    }

    .admin-note {
        margin-top: 0.6rem;
        font-size: 0.85rem;
        color: #e87070;
    }

    .empty-state {
        text-align: center;
        padding: 3rem;
        background: rgba(255,255,255,0.03);
        border: 1px dashed rgba(212,175,55,0.3);
        border-radius: 0.75rem;
        color: #7a8fa0;
    }
</style>

<div class="container mt-4" style="max-width: 760px;">
    <div class="page-header">
        <h2>📋 My Game Requests</h2>
        <a asp-action="AddGame" class="btn-gold">+ New Request</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div style="font-size:2.5rem; margin-bottom:1rem;">🎮</div>
            <p>You haven't submitted any game requests yet.</p>
            <a asp-action="AddGame" class="btn-gold" style="display:inline-block; margin-top:0.5rem;">
                Submit Your First Request
            </a>
        </div>
    }
    else
    {
        @foreach (var req in Model)
        {
            <div class="request-card @req.Status.ToString().ToLower()">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="request-title">@req.GameTitle</div>
                    <span class="status-badge status-@req.Status.ToString()">@req.Status</span>
                </div>
                <div class="request-meta">
                    Submitted: @req.SubmittedAt.ToString("MMM d, yyyy 'at' HH:mm")
                    &nbsp;·&nbsp;
                    Release: @req.ReleaseDate.ToString("MMM yyyy")
                </div>
                <div class="request-message">
                    <em>"@req.Message"</em>
                </div>
                @if (req.Status == Game_reviews.Models.AddGameRequestStatus.Denied && !string.IsNullOrEmpty(req.AdminNote))
                {
                    <div class="admin-note">❌ Admin note: <em>@req.AdminNote</em></div>
                }
            </div>
        }
    }
</div>