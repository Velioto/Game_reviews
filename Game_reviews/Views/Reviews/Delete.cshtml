@model Review

@{
    ViewData["Title"] = "Delete Review";
}

<style>
    /* Dark blue palette with gold highlights */
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    /* Headings in gold */
    h2 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
        margin: 0 0 1rem 0;
    }

    /* Delete confirmation card */
    .delete-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Confirmation message */
    .confirmation-message {
        color: #b49450;
        font-size: 1.1rem;
        margin-bottom: 1.5rem;
        text-align: center;
    }

    /* Review details grid */
    .review-details {
        background-color: #1e2a3a;
        border-radius: 0.375rem;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .detail-row {
        display: flex;
        margin-bottom: 0.75rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(212, 175, 55, 0.2);
    }

        .detail-row:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

    .detail-label {
        width: 120px;
        color: #b49450;
        font-weight: 400;
    }

    .detail-value {
        flex: 1;
        color: #e0e0e0;
        word-break: break-word;
    }

    /* Rating badge (optional, but keeps consistency) */
    .rating-badge {
        background-color: #d4af37;
        color: #0a192f;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-weight: 600;
        display: inline-block;
    }

    /* Buttons */
    .btn {
        border-radius: 0.375rem;
        transition: all 0.2s;
        font-weight: 500;
        padding: 0.6rem 1.5rem;
        text-decoration: none;
        display: inline-block;
        border: none;
        cursor: pointer;
    }

    .btn-danger {
        background-color: #b49450; /* gold instead of red */
        color: #0a192f;
    }

        .btn-danger:hover {
            background-color: #d4af37;
        }

    .btn-outline-gold {
        background-color: transparent;
        border: 1px solid #d4af37;
        color: #e0e0e0;
    }

        .btn-outline-gold:hover {
            background-color: rgba(212, 175, 55, 0.2);
            border-color: #d4af37;
            color: #d4af37;
        }

    /* Focus outline */
    a:focus-visible, button:focus-visible, .btn:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }

    /* Button group */
    .button-group {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 1.5rem;
    }

    /* Container */
    .container {
        margin-top: 3rem;
        padding: 0 1rem;
    }

    .text-center {
        text-align: center;
    }
</style>

<div class="container">
    <div class="delete-card">
        <h2 class="text-center">@ViewData["Title"]</h2>

        <div class="confirmation-message">
            Are you sure you want to permanently delete this review?
        </div>

        <div class="review-details">
            <div class="detail-row">
                <span class="detail-label">Rating</span>
                <span class="detail-value">
                    <span class="rating-badge">⭐ @Model.Rating / 10</span>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Comment</span>
                <span class="detail-value">@Model.Comment</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Game</span>
                <span class="detail-value">@(Model.Game?.Title ?? "Unknown")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Date</span>
                <span class="detail-value">@Model.CreatedOn.ToShortDateString()</span>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="button-group">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.GameId" class="btn btn-outline-gold">Cancel</a>
            </div>
        </form>
    </div>
</div>