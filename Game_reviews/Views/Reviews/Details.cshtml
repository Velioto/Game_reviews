@model Review

@using System.Security.Claims

@{
    ViewData["Title"] = "Review Details";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var canDelete = User.IsInRole("Admin") || (currentUserId != null && Model.UserId == currentUserId);
    var isAdmin = User.IsInRole("Admin");
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h3 class="mb-0">Review Details</h3>
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Game</dt>
                <dd class="col-sm-9">
                    @if (Model.Game != null)
                    {
                        <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.GameId">
                            @Model.Game.Title
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.GameId">
                            Back to Game
                        </a>
                    }
                </dd>

                <dt class="col-sm-3">Rating</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-warning text-dark">⭐ @Model.Rating / 10</span>
                </dd>

                <dt class="col-sm-3">Comment</dt>
                <dd class="col-sm-9">@Model.Comment</dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@Model.CreatedOn.ToShortDateString()</dd>
            </dl>
        </div>

        <div class="card-footer bg-white d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-secondary"
               asp-controller="Games"
               asp-action="Details"
               asp-route-id="@Model.GameId">
                ← Back to Game
            </a>

            @* Admin-only Edit (optional) *@
            @if (isAdmin)
            {
                <a class="btn btn-outline-primary"
                   asp-action="Edit"
                   asp-route-id="@Model.Id">
                    ✏️ Edit
                </a>
            }

            @* Owner or Admin can delete *@
            @if (canDelete)
            {
                <a class="btn btn-outline-danger"
                   asp-action="Delete"
                   asp-route-id="@Model.Id">
                    🗑️ Delete
                </a>
            }
        </div>
    </div>
</div>