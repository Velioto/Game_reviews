@model Review

@{
    ViewData["Title"] = "Create Review";
}

<h2>Create Review for @ViewBag.GameTitle</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="GameId" />

            <div class="form-group">
                <label asp-for="Rating" class="control-label"></label>
                <input asp-for="Rating"
                       class="form-control"
                       type="number"
                       min="1"
                       max="10"
                       required />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>

            <div class="form-group mt-2">
                <label asp-for="Comment" class="control-label"></label>
                <textarea asp-for="Comment" class="form-control" required></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.GameId">Back to Game</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}