@model Review

@{
    ViewData["Title"] = "Create Review";
}

<style>
    /* Dark blue palette with gold highlights */
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    h2 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
        margin: 0 0 0.5rem 0;
    }

    .game-title {
        color: #b49450;
        font-size: 1.2rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid rgba(212, 175, 55, 0.3);
        padding-bottom: 0.5rem;
    }

    .form-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .control-label {
        color: #b49450;
        font-weight: 400;
        margin-bottom: 0.3rem;
        display: block;
    }

    .form-control, .form-range {
        background-color: #1e2a3a;
        border: 1px solid #3a4a5a;
        color: #e0e0e0;
        border-radius: 0.375rem;
        padding: 0.6rem 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        width: 100%;
    }

        .form-control:focus, .form-range:focus {
            border-color: #d4af37;
            outline: none;
            box-shadow: 0 0 0 0.2rem rgba(212, 175, 55, 0.25);
            background-color: #2a3a4a;
            color: #ffffff;
        }

    /* Slider specific styling */
    .form-range {
        -webkit-appearance: none;
        appearance: none;
        height: 8px;
        background: #1e2a3a;
        border: 1px solid #3a4a5a;
        border-radius: 5px;
        padding: 0;
    }

        .form-range::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 20px;
            height: 20px;
            background: #b49450;
            border-radius: 50%;
            cursor: pointer;
            transition: background 0.2s;
        }

            .form-range::-webkit-slider-thumb:hover {
                background: #d4af37;
            }

        .form-range::-moz-range-thumb {
            width: 20px;
            height: 20px;
            background: #b49450;
            border: none;
            border-radius: 50%;
            cursor: pointer;
            transition: background 0.2s;
        }

            .form-range::-moz-range-thumb:hover {
                background: #d4af37;
            }

    .rating-value {
        color: #d4af37;
        font-size: 1.5rem;
        font-weight: 600;
        margin-left: 1rem;
    }

    .text-danger {
        color: #f8b4b4 !important;
        font-size: 0.85rem;
        margin-top: 0.2rem;
        display: block;
    }

    .btn {
        border-radius: 0.375rem;
        transition: all 0.2s;
        font-weight: 500;
        padding: 0.6rem 1.5rem;
        text-decoration: none;
        display: inline-block;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background-color: #b49450;
        color: #0a192f;
    }

        .btn-primary:hover {
            background-color: #d4af37;
        }

    .btn-outline-gold {
        background-color: transparent;
        border: 1px solid #d4af37;
        color: #e0e0e0;
        margin-top: 1rem;
    }

        .btn-outline-gold:hover {
            background-color: rgba(212, 175, 55, 0.2);
            border-color: #d4af37;
            color: #d4af37;
        }

    a:focus-visible, button:focus-visible, .btn:focus-visible, .form-control:focus-visible, .form-range:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .container {
        margin-top: 3rem;
        padding: 0 1rem;
    }

    .text-center {
        text-align: center;
    }

    .back-link {
        margin-top: 1.5rem;
        text-align: center;
    }

    /* Flex for rating label + value */
    .rating-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
</style>

<div class="container">
    <div class="form-card">
        <h2 class="text-center">@ViewData["Title"]</h2>
        <div class="game-title text-center">
            for @ViewBag.GameTitle
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="GameId" />

            <div class="form-group">
                <div class="rating-header">
                    <label asp-for="Rating" class="control-label"></label>
                    <span class="rating-value" id="ratingDisplay">5</span>
                </div>
                <input asp-for="Rating"
                       type="range"
                       class="form-range"
                       min="1"
                       max="10"
                       step="1"
                       value="5"
                       id="ratingSlider"
                       required />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Comment" class="control-label"></label>
                <textarea asp-for="Comment" class="form-control" rows="4" placeholder="Write your review..." required></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary w-100">Create Review</button>
            </div>
        </form>

        <div class="back-link">
            <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.GameId" class="btn-outline-gold">
                ← Back to Game
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const slider = document.getElementById('ratingSlider');
        const display = document.getElementById('ratingDisplay');
        if (slider && display) {
            display.textContent = slider.value;
            slider.addEventListener('input', function() {
                display.textContent = this.value;
            });
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}