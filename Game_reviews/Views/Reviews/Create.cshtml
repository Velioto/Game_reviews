@model Review

@{
    ViewData["Title"] = "Create";

    // FIX: ViewBag stores boxed int, so "as int?" often returns null.
    int? lockedGameId = ViewBag.LockedGameId == null ? (int?)null : (int)ViewBag.LockedGameId;
    string lockedGameTitle = ViewBag.LockedGameTitle as string;
}

<h1>Create</h1>

<h4>Review</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                 <label asp-for="Rating" class="control-label"></label>
                 <input asp-for="Rating" class="form-control" type="number" min="1" max="10" required />
                 <span asp-validation-for="Rating" class="text-danger"></span>
            </div>


            <div class="form-group">
                <label asp-for="Comment" class="control-label"></label>
                <textarea asp-for="Comment" class="form-control"></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>

            @* Locked game mode (came from Game Details) *@
            @if (lockedGameId.HasValue)
            {
                <div class="form-group">
                    <label class="control-label">Game</label>
                    <input class="form-control" value="@lockedGameTitle" readonly />
                </div>

                <input type="hidden" asp-for="GameId"/>
                <input type="hidden" name="redirectToGameId"/>
            }
            else
            {
                <div class="form-group">
                    <label asp-for="GameId" class="control-label"></label>
                    <select asp-for="GameId" class="form-control" asp-items="ViewBag.GameId"></select>
                    <span asp-validation-for="GameId" class="text-danger"></span>
                </div>
            }

            @* CreatedOn and UserId are set server-side *@

            <div class="form-group mt-2">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-2">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}