@model IEnumerable<Genre>

@{
    ViewData["Title"] = "Genres";
}

<style>
    /* Dark blue palette with gold highlights */
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    /* Headings in gold */
    h1 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
        margin: 0; /* remove default margin, will be handled by container */
    }

    /* Page header with create button */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    /* Create button – gold primary */
    .btn-create {
        background-color: #b49450;
        color: #0a192f;
        border: none;
        padding: 0.6rem 1.5rem;
        border-radius: 0.375rem;
        font-weight: 500;
        text-decoration: none;
        transition: background-color 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-create:hover {
            background-color: #d4af37;
            color: #0a192f;
            text-decoration: none;
        }

    /* Genre grid */
    .genre-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
        margin-top: 1rem;
    }

    /* Genre card */
    .genre-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        padding: 1.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        transition: transform 0.2s, border-color 0.2s;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

        .genre-card:hover {
            transform: translateY(-4px);
            border-color: #d4af37;
        }

    /* Genre name */
    .genre-name {
        color: #d4af37;
        font-size: 1.3rem;
        font-weight: 500;
        word-break: break-word;
        border-bottom: 1px solid rgba(212, 175, 55, 0.3);
        padding-bottom: 0.5rem;
    }

    /* Action buttons container */
    .card-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
        margin-top: auto;
    }

    /* Action buttons – outline gold */
    .btn-action {
        background-color: transparent;
        border: 1px solid #d4af37;
        color: #e0e0e0;
        padding: 0.4rem 1rem;
        border-radius: 0.375rem;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

        .btn-action:hover {
            background-color: rgba(212, 175, 55, 0.2);
            border-color: #d4af37;
            color: #d4af37;
            text-decoration: none;
        }

        /* Focus outline for accessibility */
        a:focus-visible, button:focus-visible, .btn-create:focus-visible, .btn-action:focus-visible {
            outline: 2px solid #d4af37;
            outline-offset: 2px;
        }

    /* Empty state */
    .empty-state {
        text-align: center;
        color: #a0b0c0;
        padding: 3rem;
        background-color: rgba(255, 255, 255, 0.03);
        border-radius: 0.5rem;
        border: 1px dashed rgba(212, 175, 55, 0.3);
        margin-top: 2rem;
    }

    /* Container */
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }
</style>

<div class="container">
    <div class="page-header">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn-create">
            <span>+</span> Create New Genre
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <p>No genres found. Click "Create New Genre" to add one.</p>
        </div>
    }
    else
    {
        <div class="genre-grid">
            @foreach (var item in Model)
            {
                <div class="genre-card">
                    <div class="genre-name">@item.Name</div>
                    <div class="card-actions">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action" title="Edit">
                            ✏️ Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action" title="Delete">
                            🗑️ Delete
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>