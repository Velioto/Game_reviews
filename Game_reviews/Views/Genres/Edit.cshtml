@model Genre

@{
    ViewData["Title"] = "Edit Genre";
}

<style>
    /* Dark blue palette with gold highlights */
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    /* Headings in gold */
    h1 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
        margin-bottom: 1.5rem;
    }

    /* Form container card */
    .form-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
        max-width: 500px;
        margin: 0 auto;
    }

    /* Form labels */
    .control-label {
        color: #b49450;
        font-weight: 400;
        margin-bottom: 0.3rem;
        display: block;
    }

    /* Form input */
    .form-control {
        background-color: #1e2a3a;
        border: 1px solid #3a4a5a;
        color: #e0e0e0;
        border-radius: 0.375rem;
        padding: 0.6rem 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        width: 100%;
    }

        .form-control:focus {
            border-color: #d4af37;
            outline: none;
            box-shadow: 0 0 0 0.2rem rgba(212, 175, 55, 0.25);
            background-color: #2a3a4a;
            color: #ffffff;
        }

    /* Validation error */
    .text-danger {
        color: #f8b4b4 !important;
        font-size: 0.85rem;
        margin-top: 0.2rem;
        display: block;
    }

    /* Buttons */
    .btn {
        border-radius: 0.375rem;
        transition: all 0.2s;
        font-weight: 500;
        padding: 0.6rem 1.5rem;
        text-decoration: none;
        display: inline-block;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background-color: #b49450;
        color: #0a192f;
    }

        .btn-primary:hover {
            background-color: #d4af37;
        }

    .btn-outline-gold {
        background-color: transparent;
        border: 1px solid #d4af37;
        color: #e0e0e0;
        margin-top: 1rem;
    }

        .btn-outline-gold:hover {
            background-color: rgba(212, 175, 55, 0.2);
            border-color: #d4af37;
            color: #d4af37;
        }

    /* Focus outline */
    a:focus-visible, button:focus-visible, .btn:focus-visible, .form-control:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }

    /* Form group spacing */
    .form-group {
        margin-bottom: 1.5rem;
    }

    /* Responsive */
    .container {
        margin-top: 3rem;
    }

    .text-center {
        text-align: center;
    }
</style>

<div class="container">
    <div class="form-card">
        <h1 class="text-center">@ViewData["Title"]</h1>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Enter genre name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary w-100">Save Changes</button>
            </div>
        </form>

        <div class="text-center">
            <a asp-action="Index" class="btn-outline-gold">← Back to List</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}