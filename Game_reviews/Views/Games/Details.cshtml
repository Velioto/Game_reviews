@model Game

@using System.Linq

<h1>Details</h1>

<div>
    <h4>Game</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.BannerUrl)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.BannerUrl)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ReleaseDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ReleaseDate)
        </dd>
    </dl>

    <h4>Genres</h4>
    @foreach (var gg in Model.GameGenres)
    {
        <span class="me-2">@gg.Genre.Name</span>
    }

    <hr />

    <div class="mb-3">
        <a class="btn btn-primary"
           asp-controller="Reviews"
           asp-action="Create"
           asp-route-gameId="@Model.Id">
            Add review
        </a>
    </div>

    <h4>Reviews</h4>

    @if (Model.Reviews == null || !Model.Reviews.Any())
    {
        <p>No reviews yet.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var r in Model.Reviews.OrderByDescending(x => x.CreatedOn))
            {
                <li class="list-group-item">
                    <div><strong>Rating:</strong> @r.Rating</div>
                    <div>@r.Comment</div>
                    <small class="text-muted">@r.CreatedOn</small>
                </li>
            }
        </ul>
    }
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>