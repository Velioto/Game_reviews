@model Game

@{
    ViewData["Title"] = "Delete";
}

<style>
    /* Dark blue palette with gold highlights */
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    /* Headings in gold */
    h1, h2, h3, h4, h5, h6 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
    }

    /* Confirmation subheading in aged gold */
    h3 {
        color: #b49450;
        font-weight: 400;
    }

    /* Card container */
    .delete-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
    }

    /* Definition list */
    dl.row {
        color: #e0e0e0;
        margin: 1.5rem 0;
    }

    dt {
        color: #b49450; /* aged gold */
        font-weight: 400;
        text-align: left;
    }

    dd {
        color: #e0e0e0;
        margin-bottom: 0.5rem;
    }

    /* Horizontal rule */
    hr {
        border-color: #d4af37;
        opacity: 0.3;
        margin: 1.5rem 0;
    }

    /* Buttons */
    .btn {
        border-radius: 0.375rem;
        transition: all 0.2s;
        font-weight: 500;
        padding: 0.6rem 1.5rem;
        text-decoration: none;
        display: inline-block;
    }

    /* Delete button – gold (primary action) */
    .btn-danger {
        background-color: #b49450; /* aged gold */
        border-color: #b49450;
        color: #0a192f;
    }

        .btn-danger:hover {
            background-color: #d4af37;
            border-color: #d4af37;
            color: #0a192f;
        }

    /* Back link as gold outline button */
    .btn-outline-gold {
        background-color: transparent;
        border: 1px solid #d4af37;
        color: #e0e0e0;
        padding: 0.6rem 1.5rem;
        border-radius: 0.375rem;
        transition: all 0.2s;
        margin-left: 0.5rem;
    }

        .btn-outline-gold:hover {
            background-color: rgba(212, 175, 55, 0.2);
            border-color: #d4af37;
            color: #d4af37;
            text-decoration: none;
        }

    /* Focus outline for accessibility */
    a:focus-visible, button:focus-visible, .btn:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }

    /* Center the card */
    .container {
        margin-top: 2rem;
    }

    .row {
        justify-content: center;
    }
</style>

<div class="container">
    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="delete-card">
                <h1>@ViewData["Title"]</h1>
                <h3 class="mb-4">Are you sure you want to delete this?</h3>
                <hr />

                <dl class="row">
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Title)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Title)</dd>

                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Description)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BannerUrl)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.BannerUrl)</dd>

                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ReleaseDate)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.ReleaseDate)</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn-outline-gold">Back to List</a>
                </form>
            </div>
        </div>
    </div>
</div>