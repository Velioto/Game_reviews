@model GameCreateViewModel

@{
    ViewData["Title"] = "Create";
    // Store current URL to return after genre creation
    var returnUrl = Url.Action("Create", "Games", null, Context.Request.Scheme);
}

<style>
    /* Dark blue palette with gold highlights */
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    /* Headings in gold */
    h1, h2, h3, h4, h5, h6 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
    }

    h4 {
        color: #b49450; /* aged gold for subheading */
    }

    /* Form container card */
    .form-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
    }

    /* Form labels */
    .control-label {
        color: #b49450;
        font-weight: 400;
        margin-bottom: 0.3rem;
        display: block;
    }

    /* Form inputs */
    .form-control {
        background-color: #1e2a3a;
        border: 1px solid #3a4a5a;
        color: #e0e0e0;
        border-radius: 0.375rem;
        padding: 0.6rem 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-control:focus {
            border-color: #d4af37;
            outline: none;
            box-shadow: 0 0 0 0.2rem rgba(212, 175, 55, 0.25);
            background-color: #2a3a4a;
            color: #ffffff;
        }

    /* Validation error text */
    .text-danger {
        color: #f8b4b4 !important;
        font-size: 0.85rem;
        margin-top: 0.2rem;
        display: block;
    }

    /* Genre checkboxes grid */
    .genre-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 0.75rem;
        margin-top: 0.5rem;
        margin-bottom: 1rem;
    }

    .genre-item {
        background-color: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.375rem;
        padding: 0.5rem 0.8rem;
        transition: background-color 0.2s;
    }

        .genre-item:hover {
            background-color: rgba(212, 175, 55, 0.1);
        }

        .genre-item input[type="checkbox"] {
            accent-color: #d4af37;
            margin-right: 0.5rem;
            transform: scale(1.1);
            cursor: pointer;
        }

        .genre-item label {
            color: #e0e0e0;
            cursor: pointer;
            margin-bottom: 0;
        }

    /* Buttons */
    .btn {
        border-radius: 0.375rem;
        transition: all 0.2s;
        font-weight: 500;
        padding: 0.6rem 1.5rem;
        text-decoration: none;
        display: inline-block;
    }

    /* Primary button – gold */
    .btn-primary {
        background-color: #b49450;
        border-color: #b49450;
        color: #0a192f;
    }

        .btn-primary:hover {
            background-color: #d4af37;
            border-color: #d4af37;
            color: #0a192f;
        }

    /* Outline gold buttons for genre management */
    .btn-outline-gold {
        background-color: transparent;
        border: 1px solid #d4af37;
        color: #e0e0e0;
    }

        .btn-outline-gold:hover {
            background-color: rgba(212, 175, 55, 0.2);
            border-color: #d4af37;
            color: #d4af37;
        }

    /* Back to List button */
    .btn-outline-secondary {
        border-color: #5a6b7a;
        color: #b0c4de;
    }

        .btn-outline-secondary:hover {
            background-color: #2a3a4a;
            border-color: #d4af37;
            color: #d4af37;
        }

    /* Focus outline for accessibility */
    a:focus-visible, button:focus-visible, .btn:focus-visible, .form-control:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }

    /* Horizontal rule */
    hr {
        border-color: #d4af37;
        opacity: 0.3;
        margin: 1.5rem 0;
    }

    /* Responsive */
    .row {
        margin-top: 2rem;
    }

    .col-md-4 {
        margin-left: auto;
        margin-right: auto;
        float: none;
        width: 100%;
        max-width: 600px; /* wider for genre grid */
    }

    .form-group {
        margin-bottom: 1.5rem;
    }
</style>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="form-card">
                <h1>@ViewData["Title"]</h1>
                <h4>Game</h4>
                <hr />

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group">
                        <label asp-for="Title" class="control-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="control-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="BannerUrl" class="control-label"></label>
                        <input asp-for="BannerUrl" class="form-control" />
                        <span asp-validation-for="BannerUrl" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ReleaseDate" class="control-label"></label>
                        <input asp-for="ReleaseDate" class="form-control" />
                        <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Genres</label>
                        <div class="genre-grid">
                            @foreach (var genre in Model.AllGenres)
                            {
                                <div class="genre-item">
                                    <input type="checkbox"
                                           name="SelectedGenreIds"
                                           value="@genre.Id"
                                           id="genre_@genre.Id" />
                                    <label for="genre_@genre.Id">@genre.Name</label>
                                </div>
                            }
                        </div>

                        <!-- Admin buttons for genre management -->
                        <div class="d-flex gap-2 mt-3">
                            <a asp-controller="Genres" asp-action="Create" asp-route-returnUrl="@returnUrl" class="btn btn-outline-gold">
                                ➕ Add Genre
                            </a>
                            <a asp-controller="Genres" asp-action="Index" class="btn btn-outline-gold">
                                👁️ See Genres
                            </a>
                        </div>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">Create</button>
                    </div>
                </form>

                <div class="mt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary">← Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}