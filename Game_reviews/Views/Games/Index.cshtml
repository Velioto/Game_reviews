@model GamesIndexViewModel

@{
    ViewData["Title"] = "Game Library";
}

<style>
    /* Dark blue palette with gold highlights – existing styles */
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    .btn-gold {
        background-color: #b49450;
        color: #0a192f;
        border: none;
        padding: 0.5rem 1.5rem;
        font-weight: 500;
        transition: background-color 0.2s;
    }

        .btn-gold:hover {
            background-color: #d4af37;
            color: #0a192f;
        }

    /* Filter bar */
    .filter-bar {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .filter-title {
        color: #d4af37;
        font-weight: 300;
        margin-bottom: 1rem;
    }

    .genre-checkbox-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    /* Custom checkboxes */
    .genre-checkbox-item {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }

        .genre-checkbox-item input[type="checkbox"] {
            position: absolute;
            opacity: 0;
            cursor: pointer;
            height: 0;
            width: 0;
        }

        .genre-checkbox-item label {
            color: #e0e0e0;
            cursor: pointer;
            padding-left: 2rem;
            position: relative;
        }

            .genre-checkbox-item label:before {
                content: '';
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 1.2rem;
                height: 1.2rem;
                background-color: #1e2a3a;
                border: 1px solid #d4af37;
                border-radius: 4px;
                transition: all 0.2s;
            }

        .genre-checkbox-item input[type="checkbox"]:checked + label:before {
            background-color: #d4af37;
            border-color: #d4af37;
        }

        .genre-checkbox-item input[type="checkbox"]:checked + label:after {
            content: '';
            position: absolute;
            left: 0.4rem;
            top: 50%;
            transform: translateY(-50%) rotate(45deg);
            width: 0.4rem;
            height: 0.7rem;
            border: solid #0a192f;
            border-width: 0 2px 2px 0;
        }

        .genre-checkbox-item input[type="checkbox"]:focus-visible + label:before {
            outline: 2px solid #d4af37;
            outline-offset: 2px;
        }

    .filter-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .btn-filter {
        background-color: #b49450;
        color: #0a192f;
        border: none;
        padding: 0.6rem 1.5rem;
        border-radius: 0.375rem;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s;
    }

        .btn-filter:hover {
            background-color: #d4af37;
        }

    .btn-clear {
        background-color: transparent;
        border: 1px solid #d4af37;
        color: #e0e0e0;
        padding: 0.6rem 1.5rem;
        border-radius: 0.375rem;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-clear:hover {
            background-color: rgba(212, 175, 55, 0.2);
            border-color: #d4af37;
            color: #d4af37;
        }

    /* Banner gallery – unchanged */
    .banner-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
        justify-items: center;
        margin-top: 2rem;
    }

    .game-banner-wrapper {
        width: 100%;
        max-width: 360px;
        aspect-ratio: 9 / 16;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 2px solid transparent;
    }

        .game-banner-wrapper:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.7);
            border-color: #d4af37;
        }

    .game-banner-link {
        display: block;
        width: 100%;
        height: 100%;
        text-decoration: none;
        color: inherit;
    }

    .game-banner {
        width: 100%;
        height: 100%;
        background-size: cover;
        background-position: center;
        position: relative;
        border-radius: 4px;
        overflow: hidden;
    }

    .banner-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(10, 25, 47, 0.85);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 1.2rem;
        opacity: 0;
        transition: opacity 0.2s ease;
        color: #f0f0f0;
        backdrop-filter: blur(2px);
    }

    .game-banner:hover .banner-overlay {
        opacity: 1;
    }

    .banner-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .game-name {
        font-size: 1.3rem;
        font-weight: 600;
        line-height: 1.2;
        color: #d4af37;
        text-shadow: 0 1px 3px rgba(0,0,0,0.8);
        word-break: break-word;
    }

    .game-rating {
        background: #d4af37;
        color: #0a192f;
        padding: 0.2rem 0.5rem;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .banner-footer {
        font-size: 0.9rem;
        line-height: 1.4;
        max-height: 40%;
        overflow-y: auto;
        padding-right: 0.3rem;
        color: #dddddd;
    }

        .banner-footer p {
            margin: 0;
        }

        .banner-footer::-webkit-scrollbar {
            width: 4px;
        }

        .banner-footer::-webkit-scrollbar-thumb {
            background: #d4af37;
            border-radius: 4px;
        }

    .admin-toolbar {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 2rem;
    }

    a:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }

    /* No games message */
    .no-games {
        text-align: center;
        padding: 3rem;
        background-color: rgba(255, 255, 255, 0.03);
        border: 1px dashed rgba(212, 175, 55, 0.3);
        border-radius: 0.5rem;
        color: #a0b0c0;
    }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div></div>
        @if (User.IsInRole("Admin"))
        {
            <div class="admin-toolbar">
                <a asp-action="Create" class="btn-gold">+ Create New Game</a>
            </div>
        }
    </div>

    <!-- Genre Filter -->
    <div class="filter-bar">
        <h3 class="filter-title">Filter by Genre</h3>
        <form method="get" asp-action="Index">
            <div class="genre-checkbox-grid">
                @foreach (var genre in Model.AllGenres)
                {
                    <div class="genre-checkbox-item">
                        <input type="checkbox"
                               name="selectedGenres"
                               value="@genre.Id"
                               id="genre_@genre.Id"
                               @(Model.SelectedGenreIds.Contains(genre.Id) ? "checked" : "") />
                        <label for="genre_@genre.Id">@genre.Name</label>
                    </div>
                }
            </div>
            <div class="filter-actions">
                <button type="submit" class="btn-filter">Apply Filter</button>
                <a asp-action="Index" class="btn-clear">Clear Filter</a>
            </div>
        </form>
    </div>

    <!-- Banner Grid -->
    @if (!Model.Games.Any())
    {
        <div class="no-games">
            No games match the selected filters.
        </div>
    }
    else
    {
        <div class="banner-gallery">
            @foreach (var item in Model.Games)
            {
                var avgRating = item.Reviews != null && item.Reviews.Any()
                ? item.Reviews.Average(r => r.Rating).ToString("0.0")
                : "N/A";

                var shortDesc = item.Description?.Length > 120
                ? item.Description.Substring(0, 120) + "…"
                : item.Description ?? "No description available.";

                <div class="game-banner-wrapper">
                    <a asp-action="Details" asp-route-id="@item.Id" class="game-banner-link">
                        <div class="game-banner"
                             style="background-image: url('@(item.BannerUrl ?? "/images/placeholder.jpg")');"
                             onerror="this.style.backgroundImage='url(/images/placeholder.jpg)'">
                            <div class="banner-overlay">
                                <div class="banner-header">
                                    <span class="game-name">@item.Title</span>
                                    <span class="game-rating">⭐ @avgRating</span>
                                </div>
                                <div class="banner-footer">
                                    <p>@shortDesc</p>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>