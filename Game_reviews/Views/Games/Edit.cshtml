@model Game

@{
    ViewData["Title"] = "Edit";
}

<style>
    /* Dark blue palette with gold highlights */
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    /* Headings in gold */
    h1, h2, h3, h4, h5, h6, .display-6, .card-title {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
    }

    /* Form container card */
    .form-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
    }

    /* Form labels */
    .control-label {
        color: #b49450; /* aged gold */
        font-weight: 400;
        margin-bottom: 0.3rem;
        display: block;
    }

    /* Form inputs */
    .form-control {
        background-color: #1e2a3a;
        border: 1px solid #3a4a5a;
        color: #e0e0e0;
        border-radius: 0.375rem;
        padding: 0.6rem 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-control:focus {
            border-color: #d4af37;
            outline: none;
            box-shadow: 0 0 0 0.2rem rgba(212, 175, 55, 0.25);
            background-color: #2a3a4a;
            color: #ffffff;
        }

    /* Validation error text */
    .text-danger {
        color: #f8b4b4 !important; /* soft red for errors */
        font-size: 0.85rem;
        margin-top: 0.2rem;
        display: block;
    }

    /* Buttons */
    .btn {
        border-radius: 0.375rem;
        transition: all 0.2s;
        font-weight: 500;
        padding: 0.6rem 1.5rem;
    }

    /* Primary button (Save) – gold */
    .btn-primary {
        background-color: #b49450; /* aged gold */
        border-color: #b49450;
        color: #0a192f;
    }

        .btn-primary:hover {
            background-color: #d4af37;
            border-color: #d4af37;
            color: #0a192f;
        }

    /* Back link styled as gold outline button */
    .btn-outline-gold {
        background-color: transparent;
        border: 1px solid #d4af37;
        color: #e0e0e0;
        padding: 0.6rem 1.5rem;
        text-decoration: none;
        border-radius: 0.375rem;
        transition: all 0.2s;
        display: inline-block;
        margin-top: 1rem;
    }

        .btn-outline-gold:hover {
            background-color: rgba(212, 175, 55, 0.2);
            border-color: #d4af37;
            color: #d4af37;
            text-decoration: none;
        }

    /* Focus outline for accessibility */
    a:focus-visible, button:focus-visible, .btn:focus-visible, .form-control:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }

    /* Responsive adjustments */
    .row {
        margin-top: 2rem;
    }

    .col-md-4 {
        margin-left: auto;
        margin-right: auto;
        float: none;
    }

    /* Spacing */
    .form-group {
        margin-bottom: 1.5rem;
    }

    /* Horizontal rule styling */
    hr {
        border-color: #d4af37;
        opacity: 0.3;
        margin: 1.5rem 0;
    }
</style>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 col-lg-6 mx-auto">
            <div class="form-card">
                <h1 class="display-6 mb-4">@ViewData["Title"]</h1>
                <h4 class="mb-4" style="color: #b49450;">Game</h4>
                <hr />

                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label asp-for="Title" class="control-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="control-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="BannerUrl" class="control-label"></label>
                        <input asp-for="BannerUrl" class="form-control" />
                        <span asp-validation-for="BannerUrl" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ReleaseDate" class="control-label"></label>
                        <input asp-for="ReleaseDate" class="form-control" />
                        <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>

                <div class="mt-3">
                    <a asp-action="Index" class="btn-outline-gold">← Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}