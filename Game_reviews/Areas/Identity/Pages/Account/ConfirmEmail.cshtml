@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm Email";
}

<style>
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    .confirm-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
        max-width: 500px;
        margin: 3rem auto;
        text-align: center;
    }

    h1 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
    }

    .status-message {
        color: #b49450;
        font-size: 1.1rem;
    }

    a:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }
</style>

<div class="container">
    <div class="confirm-card">
        <h1>@ViewData["Title"]</h1>
        <div class="status-message">
            <partial name="_StatusMessage" model="Model.StatusMessage" />
        </div>
        <a asp-controller="Games" asp-action="Index" class="btn-outline-gold" style="margin-top: 1.5rem; display: inline-block; padding: 0.6rem 1.5rem; border: 1px solid #d4af37; border-radius: 0.375rem; color: #e0e0e0; text-decoration: none;">← Back to Home</a>
    </div>
</div>