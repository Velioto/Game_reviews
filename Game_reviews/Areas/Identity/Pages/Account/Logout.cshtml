@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<style>
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    .logout-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
        max-width: 500px;
        margin: 3rem auto;
        text-align: center;
    }

    h1 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
    }

    p {
        color: #e0e0e0;
        font-size: 1.1rem;
    }

    .btn-primary {
        background-color: #b49450;
        border: none;
        color: #0a192f;
        padding: 0.6rem 1.5rem;
        border-radius: 0.375rem;
        font-weight: 500;
        transition: all 0.2s;
    }

        .btn-primary:hover {
            background-color: #d4af37;
        }

    a:focus-visible, button:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }
</style>

<div class="container">
    <div class="logout-card">
        <h1>@ViewData["Title"]</h1>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="btn-primary">Click here to Logout</button>
            </form>
        }
        else
        {
            <p>You have successfully logged out.</p>
            <a asp-controller="Games" asp-action="Index" class="btn-outline-gold" style="margin-top: 1rem; display: inline-block; padding: 0.6rem 1.5rem; border: 1px solid #d4af37; border-radius: 0.375rem; color: #e0e0e0; text-decoration: none;">← Back to Home</a>
        }
    </div>
</div>