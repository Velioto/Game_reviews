@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<style>
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    .login-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
        max-width: 500px;
        margin: 2rem auto;
    }

    h1, h2, h3 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
    }

    h2 {
        font-size: 1.4rem;
        margin-bottom: 1rem;
    }

    .form-floating {
        margin-bottom: 1rem;
    }

    .form-control {
        background-color: #1e2a3a;
        border: 1px solid #3a4a5a;
        color: #e0e0e0;
        border-radius: 0.375rem;
        padding: 0.6rem 1rem;
        width: 100%;
    }

        .form-control:focus {
            border-color: #d4af37;
            outline: none;
            box-shadow: 0 0 0 0.2rem rgba(212, 175, 55, 0.25);
            background-color: #2a3a4a;
        }

    .form-label {
        color: #b49450;
        font-weight: 400;
    }

    .checkbox label {
        color: #e0e0e0;
    }

    .btn-primary {
        background-color: #b49450;
        border-color: #b49450;
        color: #0a192f;
        border-radius: 0.375rem;
        padding: 0.6rem 1.5rem;
        font-weight: 500;
        transition: all 0.2s;
        width: 100%;
    }

        .btn-primary:hover {
            background-color: #d4af37;
            border-color: #d4af37;
        }

    .btn-outline-gold {
        background-color: transparent;
        border: 1px solid #d4af37;
        color: #e0e0e0;
        padding: 0.6rem 1.5rem;
        border-radius: 0.375rem;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-block;
    }

        .btn-outline-gold:hover {
            background-color: rgba(212, 175, 55, 0.2);
            border-color: #d4af37;
            color: #d4af37;
        }

    a:focus-visible, button:focus-visible {
        outline: 2px solid #d4af37;
        outline-offset: 2px;
    }

    .text-danger {
        color: #f8b4b4 !important;
    }

    .external-login {
        margin-top: 2rem;
        text-align: center;
    }
</style>

<div class="container">
    <div class="login-card">
        <h1 class="text-center">@ViewData["Title"]</h1>
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password" class="form-label">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="checkbox mb-3">
                <label asp-for="Input.RememberMe" class="form-label">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>
            <div>
                <button id="login-submit" type="submit" class="btn-primary">Log in</button>
            </div>
            <div class="mt-3 text-center">
                <p>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn-outline-gold" style="margin: 0.2rem;">Register as new user</a>
                </p>
            </div>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="external-login">
                <h3>Or use an external service</h3>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div>
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn-outline-gold" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account" style="margin: 0.2rem;">
                                @provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}