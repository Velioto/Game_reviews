@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register Confirmation";
}

<style>
    body {
        background-color: #0a192f;
        color: #e0e0e0;
    }

    .confirm-card {
        background-color: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 0.5rem;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        padding: 2rem;
        max-width: 600px;
        margin: 3rem auto;
        text-align: center;
    }

    h1 {
        color: #d4af37;
        font-weight: 300;
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
    }

    p {
        color: #e0e0e0;
        font-size: 1.1rem;
    }

    a {
        color: #d4af37;
        text-decoration: none;
    }

        a:hover {
            text-decoration: underline;
        }

        a:focus-visible {
            outline: 2px solid #d4af37;
            outline-offset: 2px;
        }
</style>

<div class="container">
    <div class="confirm-card">
        <h1>@ViewData["Title"]</h1>
        @if (Model.DisplayConfirmAccountLink)
        {
            <p>
                This app does not currently have a real email sender registered. Normally this would be emailed:
                <br />
                <a id="confirm-link" href="@Model.EmailConfirmationUrl">Click here to confirm your account</a>
            </p>
        }
        else
        {
            <p>Please check your email to confirm your account.</p>
        }
        <a asp-controller="Games" asp-action="Index" class="btn-outline-gold" style="margin-top: 1.5rem; display: inline-block; padding: 0.6rem 1.5rem; border: 1px solid #d4af37; border-radius: 0.375rem; color: #e0e0e0; text-decoration: none;">← Back to Home</a>
    </div>
</div>